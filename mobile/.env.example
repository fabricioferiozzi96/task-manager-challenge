# Copiar este archivo a `.env` y ajustar valores.
# El `.env` está en .gitignore.
#
# Android emulator usa 10.0.2.2 como alias para el localhost del host.
# iOS Simulator comparte red con la Mac, usa localhost directo.
# Para device físico: usar la IP de la máquina en la red local.

API_URL_ANDROID=http://10.0.2.2:5186/api
API_URL_IOS=http://localhost:5186/api
