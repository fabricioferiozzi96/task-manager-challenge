# Copiar este archivo a `.env` y ajustar valores.
# El `.env` está en .gitignore (no se commitea con credenciales reales).
#
# .NET resuelve variables de entorno con doble underscore como secciones anidadas
# en IConfiguration: ConnectionStrings__Default => ConnectionStrings:Default.

ConnectionStrings__Default=Host=localhost;Port=5432;Database=taskmanager;Username=postgres;Password=postgres
